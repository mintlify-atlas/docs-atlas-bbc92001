  "keyFeatures": [
    "Multi-channel notification delivery (Nova, Card, Email, SMS, WhatsApp, Web Push, Slack, Teams)",
    "Automatic channel escalation with configurable timeout thresholds",
    "Smart retries with escalating delay intervals",
    "Audience segmentation: static, dynamic, and segment-based audiences",
    "Five delivery strategies: marketing, transactional, system, alert, reminder",
    "Built-in open and action tracking with unique slugs per delivery",
    "Google Analytics GA4 integration for notification tracking",
    "Time window and day-of-week delivery scheduling",
    "Laravel Nova dashboard for managing notifications, audiences, and deliveries",
    "Web push notifications via service workers (HTTPS required)"
  ],
